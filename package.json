{
	"name": "resourceloader-js",
	"version": "1.0.2",
	"description": "A flexible JavaScript library for dynamic resource loading",
	"main": "resourceLoader.js",
	"browser": "resourceLoader.js",
	"unpkg": "resourceLoader.js",
	"jsdelivr": "resourceLoader.js",
	"exports": {
		".": "./resourceLoader.js"
	},
	"files": [
		"resourceLoader.js",
		"README.md",
		"LICENSE"
	],
	"keywords": [
		"resource-loader",
		"script-loader",
		"css-loader",
		"dynamic-loading",
		"javascript"
	],
	"author": "Peter Benoit",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/peterbenoit/ResourceLoader.js.git"
	},
	"bugs": {
		"url": "https://github.com/peterbenoit/ResourceLoader.js/issues"
	},
	"homepage": "https://github.com/peterbenoit/ResourceLoader.js#readme",
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"pack:dry-run": "npm pack --dry-run",
		"prepublishOnly": "npm test && npm run pack:dry-run",
		"release": "node scripts/release.js",
		"release:patch": "node scripts/release.js --bump patch"
	},
	"devDependencies": {
		"jsdom": "^24.1.3",
		"vitest": "^2.1.8"
	}
}
